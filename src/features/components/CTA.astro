---
import ActionButton from "@/features/base/ActionButton.astro";
import ImgComp from "@/features/base/ImgComp.astro";

const { title, priBtn, secBtn, ctaImg, statsList } = Astro.props;
---

<section
  class="bg-base-200 relative isolate max-md:flex max-md:flex-col-reverse"
>
  <div class="container py-7.5 md:py-15 lg:py-20">
    <div class="space-y-10 md:space-y-15 lg:space-y-25">
      <div class="w-full md:w-1/2 lg:w-2/5">
        <h2 class="text-[26px]/[1.4] md:text-[28px]/[1.3] lg:text-[38px]/[1.3]">
          {title}
        </h2>

        <div class="mt-6.25 md:mt-7.5 lg:mt-10 flex gap-3.75">
          {
            priBtn.content === "" ? null : (
              <ActionButton button={priBtn} type="primary" />
            )
          }
          {
            secBtn.content === "" ? null : (
              <ActionButton button={secBtn} type="outline" />
            )
          }
        </div>
      </div>

      <div class="grid grid-cols-2 md:flex items-center gap-7.5 lg:gap-20">
        {
          statsList.map((stat: { value: string; description: string }) => (
            <div class="max-md:*:even:ml-auto">
              <div class="md:contents  w-max">
                <p class="text-[26px]/none md:text-3xl/none lg:text-[50px]/none mb-2 lg:mb-3 text-black">
                  {stat.value}
                </p>
                <p class="text-sm/normal md:text-xs/normal lg:text-base/normal text-accent">
                  {stat.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div
    class="md:absolute top-0 h-full relative right-0 w-full md:w-[42%] lg:w-[46%] -z-1 rightSlide"
  >
    <ImgComp
      width="1100"
      height="600"
      class="max-w-full w-full h-65 md:h-full object-cover"
      data-animate
      img={ctaImg}
    />
  </div>
</section>
